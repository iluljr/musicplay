FROM node:22-alpine AS build
WORKDIR /app/backend

COPY backend/package*.json ./
RUN npm ci

COPY backend ./
RUN npm run build

FROM node:22-alpine
WORKDIR /app/backend

COPY backend/package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/backend/dist ./dist

RUN mkdir -p uploads data

EXPOSE 3001
CMD ["npm", "run", "start"]
